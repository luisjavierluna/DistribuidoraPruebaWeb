@model Producto

@{
    ViewData["Title"] = Model.Id == 0 ? "Crear Producto" : "Editar Producto";
    bool esCreacion = Model.Id == 0;
    string accion = esCreacion ? "Create" : "Edit";
}

<div class="container">
    <h2 class="mb-4">@(esCreacion ? "Crear Producto" : "Editar Producto")</h2>

    <form method="post" action="@Url.Action(accion, "Home")" class="form">
        <input type="hidden" name="id" value="@Model.Id">

        <div class="filter-row">
            <div class="form-control">
                <label for="clave" class="form-label">Clave</label>
                <input type="text" class="form-control" id="clave" name="clave" value="@Model.Clave" required>
            </div>
            <div class="form-control">
                <label for="nombre" class="form-label">Nombre</label>
                <input type="text" class="form-control" id="nombre" name="nombre" value="@Model.Nombre" required>
            </div>
        </div>

        <div class="filter-row">
            <div class="form-control">
                <label for="productTypeId" class="form-label">Tipo Producto</label>
                <select class="form-select" id="productTypeId" name="productTypeId" required>
                    <option value="">Seleccionar...</option>
                    @{
                        var tiposProducto = (List<Distribuidora.Application.DTOs.ProductTypeDto>)(ViewBag.TiposProducto ?? new List<Distribuidora.Application.DTOs.ProductTypeDto>());
                        var productTypeId = Model.Id == 0 ? 0 : (tiposProducto.FirstOrDefault(t => t.Name == Model.TipoProducto)?.Id ?? 0);
                    }
                    @foreach (var tipo in tiposProducto.OrderBy(t => t.Name))
                    {
                        if (productTypeId == tipo.Id)
                        {
                            <option value="@tipo.Id" selected>@tipo.Name</option>
                        }
                        else
                        {
                            <option value="@tipo.Id">@tipo.Name</option>
                        }
                    }
                </select>
            </div>
            <div class="form-control">
                <label for="precio" class="form-label">Precio</label>
                <input type="number" class="form-control" id="precio" name="precio" step="0.01" value="@Model.Precio" required>
            </div>
        </div>

        <div class="filter-row">
            <div class="form-control">
                <label for="esActivo" class="form-label">Es Activo</label>
                <div class="form-check mt-2">
                    @{
                        var checkedAttr = Model.EsActivo ? "checked" : "";
                    }
                    <text><input class="form-check-input" type="checkbox" id="esActivo" name="esActivo" @checkedAttr></text>
                    <label class="form-check-label" for="esActivo">
                        Producto Activo
                    </label>
                </div>
            </div>
        </div>

        <hr>

        <!-- Sección de Proveedores -->
        <h4 class="mb-3">Proveedores</h4>

        @if (Model.Proveedores != null && Model.Proveedores.Count > 0)
        {
            <div class="table-responsive mb-3">
                <table class="table table-striped table-hover">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 60px; text-align: center;">Editar</th>
                            <th style="text-align: center;">Proveedor</th>
                            <th style="text-align: center;">Clave Producto</th>
                            <th style="width: 100px; text-align: center;">Costo</th>
                            <th style="width: 60px; text-align: center;">Eliminar</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var proveedor in Model.Proveedores)
                        {
                            <tr>
                                <td class="text-center">
                                    <button type="button" class="btn btn-sm btn-light" data-bs-toggle="modal" data-bs-target="#agregarProveedorModal" onclick="editarProveedor(@proveedor.Id)">
                                        ✏️
                                    </button>
                                </td>
                                <td>@proveedor.Nombre</td>
                                <td>@proveedor.ClaveProducto</td>
                                <td>$@proveedor.Costo.ToString("F2")</td>
                                <td class="text-center">
                                    <button type="button" class="btn btn-sm btn-light" onclick="eliminarProveedor(@proveedor.Id)">
                                        <span style="color: red; font-weight: bold;">✕</span>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        <div class="form-button">
            <button type="button" class="btn btn-link" data-bs-toggle="modal" data-bs-target="#agregarProveedorModal" onclick="nuevoProveedor()">
                Agregar Proveedor
            </button>
        </div>

        <hr>

        <!-- Botones de guardado -->
        <div class="form-button">
            <button type="submit" class="btn btn-primary">@(esCreacion ? "Crear" : "Guardar")</button>
            <a href="@Url.Action("Index", "Home")" class="btn btn-secondary">Cancelar</a>
        </div>
    </form>
</div>

<!-- Modal para Agregar/Editar Proveedor -->
@await Html.PartialAsync("_AgregarProveedorModal", new Proveedor())

@section Scripts {
    <script>
        function nuevoProveedor() {
            document.getElementById('proveedorForm').reset();
            document.getElementById('modalTitle').textContent = 'Agregar Proveedor';
        }

        function editarProveedor(id) {
            document.getElementById('modalTitle').textContent = 'Editar Proveedor';
        }

        function eliminarProveedor(id) {
            if (confirm('¿Estás seguro de que deseas eliminar este proveedor?')) {
                alert('Proveedor eliminado (por implementar)');
            }
        }

        function guardarProveedor() {
            const nombre = document.getElementById('nombre').value;
            const clave = document.getElementById('claveProducto').value;
            const costo = document.getElementById('costo').value;

            if (!nombre || !clave || !costo) {
                alert('Por favor completa todos los campos');
                return;
            }

            alert('Proveedor guardado (por implementar)');
            const modal = bootstrap.Modal.getInstance(document.getElementById('agregarProveedorModal'));
            modal.hide();
        }
    </script>
}
