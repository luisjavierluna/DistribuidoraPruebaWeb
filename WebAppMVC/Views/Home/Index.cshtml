@model List<Producto>

@{
    ViewData["Title"] = "Listado de Productos";
}

<div class="container">
    <!-- Filtros -->
    <form method="get" action="@Url.Action("Index", "Home")" class="form">
        <div class="filter-row">
            <div class="form-control">
                <label for="clave" class="form-label">Clave</label>
                <input type="text" class="form-control" id="clave" name="clave" value="@Context.Request.Query["clave"]">
            </div>
            <div class="form-control">
                <label for="tipoProducto" class="form-label">Tipo de Producto</label>
                <select class="form-select" id="tipoProducto" name="tipoProducto">
                    @{
                        var tiposProducto = new[] { "Limpieza", "Higiene", "Alimentos", "Bebidas" };
                        var tipoSeleccionado = Context.Request.Query["tipoProducto"].ToString();
                    }
                    <option value="">Seleccionar...</option>
                    @foreach (var tipo in tiposProducto)
                    {
                        if (tipo == tipoSeleccionado)
                        {
                            <text><option value="@tipo" selected="selected">@tipo</option></text>
                        }
                        else
                        {
                            <text><option value="@tipo">@tipo</option></text>
                        }
                    }
                </select>
            </div>
        </div>
        <div class="row">
            <div class="form-button">
                <button type="submit" class="btn btn-primary">Buscar</button>
            </div>
        </div>
    </form>

    <!-- Tabla de Productos -->
    @if (Model != null && Model.Count > 0)
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-light">
                    <tr>
                        <th style="width: 60px; text-align: center;">Editar</th>
                        <th style="text-align: center;">Producto</th>
                        <th style="text-align: center;">Clave Producto</th>
                        <th style="width: 100px; text-align: center;">Precio</th>
                        <th style="width: 60px; text-align: center;">Eliminar</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var producto in Model)
                    {
                        <tr>
                            <td class="text-center">
                                <a href="@Url.Action("Edit", "Home", new { id = producto.Id })" class="btn btn-sm btn-light">
                                    <i class="bi bi-pencil">✏️</i>
                                </a>
                            </td>
                            <td>@producto.Nombre</td>
                            <td>@producto.Clave</td>
                            <td>$@producto.Precio.ToString("F2")</td>
                            <td class="text-center">
                                <a href="@Url.Action("Delete", "Home", new { id = producto.Id })" class="btn btn-sm btn-light" onclick="return confirm('¿Estás seguro de que deseas eliminar este producto?');">
                                    <span style="color: red; font-weight: bold;">✕</span>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else if (Model != null)
    {
        <div class="alert alert-info">
            No hay productos que coincidan con los criterios de búsqueda.
        </div>
    }

    <!-- Botón Agregar -->
    <div class="row">
        <div class="form-button">
            <a href="@Url.Action("Create", "Home")" class="btn btn-primary">Agregar</a>
        </div>
    </div>
</div>
